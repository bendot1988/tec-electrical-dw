---
import {
	cookieConsentMaxAge,
	cookieConsentName,
	gaMeasurementId,
} from '../data/siteAnalytics';
---

<div id="cookie-banner" class="cookie-banner" hidden>
	<div class="cookie-banner-panel" role="dialog" aria-labelledby="cookie-banner-title" aria-live="polite">
		<div class="cookie-banner-copy">
			<p id="cookie-banner-title" class="cookie-banner-title">Cookies on this site</p>
			<p class="cookie-banner-text">
				We use optional analytics cookies to understand how the website is used and improve it. Essential cookies
				remember your choice. See our <a href="/privacy">Privacy Policy</a> for details.
			</p>
		</div>
		<div class="cookie-banner-actions">
			<button type="button" class="cookie-btn cookie-btn-reject" id="cookie-reject">
				Reject non-essential
			</button>
			<button type="button" class="cookie-btn cookie-btn-accept" id="cookie-accept">Accept</button>
		</div>
	</div>
</div>

<script
	is:inline
	define:vars={{ gaMeasurementId, cookieConsentName, cookieConsentMaxAge }}
>
	const banner = document.getElementById('cookie-banner');
	const acceptBtn = document.getElementById('cookie-accept');
	const rejectBtn = document.getElementById('cookie-reject');
	const settingsTriggers = document.querySelectorAll('[data-cookie-settings]');

	function getConsent() {
		const match = document.cookie.match(new RegExp(`(?:^|; )${cookieConsentName}=([^;]*)`));
		return match ? decodeURIComponent(match[1]) : '';
	}

	function setConsent(value) {
		document.cookie = `${cookieConsentName}=${encodeURIComponent(value)}; path=/; max-age=${cookieConsentMaxAge}; SameSite=Lax`;
	}

	function showBanner() {
		banner?.removeAttribute('hidden');
	}

	function hideBanner() {
		banner?.setAttribute('hidden', '');
	}

	function grantAnalyticsConsent() {
		if (typeof gtag === 'function') {
			gtag('consent', 'update', { analytics_storage: 'granted' });
		}
	}

	function denyAnalyticsConsent() {
		if (typeof gtag === 'function') {
			gtag('consent', 'update', { analytics_storage: 'denied' });
		}
	}

	function removeGoogleAnalytics() {
		document.getElementById('tec-ga-script')?.remove();
	}

	function loadGoogleAnalytics() {
		if (!gaMeasurementId || document.getElementById('tec-ga-script')) return;

		window.dataLayer = window.dataLayer || [];
		if (typeof gtag !== 'function') {
			function gtag() {
				dataLayer.push(arguments);
			}
			window.gtag = gtag;
		}

		gtag('js', new Date());
		gtag('config', gaMeasurementId);

		const script = document.createElement('script');
		script.id = 'tec-ga-script';
		script.async = true;
		script.src = `https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`;
		document.head.appendChild(script);
	}

	function applyConsent(choice) {
		if (choice === 'accepted') {
			grantAnalyticsConsent();
			loadGoogleAnalytics();
		} else {
			denyAnalyticsConsent();
			removeGoogleAnalytics();
		}
		hideBanner();
	}

	const consent = getConsent();

	if (consent === 'accepted') {
		applyConsent('accepted');
	} else if (consent === 'declined') {
		applyConsent('declined');
	} else {
		showBanner();
	}

	acceptBtn?.addEventListener('click', () => {
		setConsent('accepted');
		applyConsent('accepted');
	});

	rejectBtn?.addEventListener('click', () => {
		setConsent('declined');
		applyConsent('declined');
	});

	settingsTriggers.forEach((trigger) => {
		trigger.addEventListener('click', (event) => {
			event.preventDefault();
			showBanner();
		});
	});
</script>

<style>
	.cookie-banner {
		position: fixed;
		inset: auto 0 0;
		z-index: 110;
		padding: 0.85rem var(--site-content-padding) 1rem;
		pointer-events: none;
	}

	.cookie-banner-panel {
		pointer-events: auto;
		max-width: 52rem;
		margin: 0 auto;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 1rem 1.25rem;
		padding: 1rem 1.15rem;
		background: #ffffff;
		border: 1px solid #e2e8f0;
		border-radius: 0.95rem;
		box-shadow:
			0 18px 40px -28px rgba(15, 23, 42, 0.45),
			0 4px 14px -10px rgba(15, 23, 42, 0.2);
	}

	.cookie-banner-copy {
		flex: 1 1 16rem;
		min-width: 0;
	}

	.cookie-banner-title {
		margin: 0;
		font-family: var(--font-heading);
		font-size: 0.92rem;
		font-weight: 600;
		color: #0f172a;
		letter-spacing: -0.01em;
	}

	.cookie-banner-text {
		margin: 0.35rem 0 0;
		font-size: 0.84rem;
		line-height: 1.55;
		color: #64748b;
	}

	.cookie-banner-text a {
		color: #0f4ac4;
		text-decoration: underline;
		text-underline-offset: 0.12em;
	}

	.cookie-banner-text a:hover {
		color: #3567ab;
	}

	.cookie-banner-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		flex-shrink: 0;
	}

	.cookie-btn {
		font-family: var(--font-body);
		font-size: 0.84rem;
		font-weight: 600;
		line-height: 1;
		padding: 0.62rem 1.05rem;
		border-radius: var(--radius-button);
		cursor: pointer;
		transition:
			background-color 160ms ease,
			border-color 160ms ease,
			color 160ms ease;
	}

	.cookie-btn-reject {
		background: transparent;
		border: 1px solid #e2e8f0;
		color: #64748b;
	}

	.cookie-btn-reject:hover {
		border-color: #cbd5e1;
		color: #475569;
		background: #f8fafc;
	}

	.cookie-btn-accept {
		border: 1px solid #fde68a;
		background: #fffbeb;
		color: #92400e;
	}

	.cookie-btn-accept:hover {
		background: #fef3c7;
		border-color: #fcd34d;
		color: #78350f;
	}

	@media (max-width: 640px) {
		.cookie-banner-panel {
			flex-direction: column;
			align-items: stretch;
		}

		.cookie-banner-actions {
			width: 100%;
		}

		.cookie-btn {
			flex: 1 1 auto;
			justify-content: center;
			text-align: center;
		}
	}
</style>
