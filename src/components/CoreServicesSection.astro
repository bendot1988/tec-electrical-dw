---
const serviceCards = [
	{
		title: 'General Electrical & New Builds',
		items: [
			'New Builds',
			'Student/HMO Accommodation',
			'Emergency Lighting',
			'Fire Alarms',
			'Intercoms',
			'Lighting & Power Design',
		],
		icon: '🏢',
	},
	{
		title: 'Fault Finding & Maintenance',
		items: ['In-depth Diagnostics', 'Energy Logging', 'Thermal Imaging', 'Maintenance Packages', 'Landlord EICRs', 'PAT Testing'],
		icon: '🔎',
		featured: true,
	},
	{
		title: 'Solar, Battery & EV',
		items: [
			'In-roof & On-roof Solar',
			'Battery Storage with Backup',
			'Load Shifting',
			'Full Install & Handover',
			'Optimisation',
			'EV Charging',
		],
		icon: '☀',
	},
];

const serviceTags = ['Domestic', 'Commercial', 'Safety', 'Inspection', 'Maintenance', 'EV Charging'];
---

<section class="core-services" aria-labelledby="core-services-heading">
	<div class="core-services-wrap">
		<header class="services-head" data-reveal>
			<p>What We Do</p>
			<h2 id="core-services-heading">Our Core Services</h2>
			<span>
				From domestic installations to commercial projects, we deliver comprehensive electrical solutions
				across Leicestershire.
			</span>
		</header>

		<div class="services-grid">
			{
				serviceCards.map((service, index) => (
					<article
						class:list={['service-card', service.featured && 'featured']}
						data-reveal
						style={`--reveal-delay: ${110 + index * 100}ms;`}
					>
						<div class="card-image">
							<img src="/package-placeholder.svg" alt="" loading="lazy" />
						</div>

						<div class="card-icon" aria-hidden="true">{service.icon}</div>
						<h3>{service.title}</h3>
						<ul>
							{service.items.map((item) => <li>{item}</li>)}
						</ul>
					</article>
				))
			}
		</div>

		<div class="service-tags" data-reveal style="--reveal-delay: 360ms;">
			{
				serviceTags.map((tag) => (
					<span>{tag}</span>
				))
			}
		</div>
	</div>
</section>

<style>
	.core-services {
		background: #f8fafc;
		padding: 5.2rem var(--site-content-padding) 5.8rem;
	}

	.core-services-wrap {
		max-width: 1200px;
		margin: 0 auto;
	}

	.services-head {
		text-align: center;
		max-width: 760px;
		margin: 0 auto 2.1rem;
	}

	.services-head p {
		margin: 0;
		font-size: 0.78rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #3567ab;
	}

	.services-head h2 {
		margin: 0.55rem 0 0.65rem;
		font-size: clamp(2rem, 3vw, 3rem);
		line-height: 1.1;
		color: #0f172a;
	}

	.services-head span {
		display: block;
		font-size: 1.02rem;
		line-height: 1.55;
		color: #64748b;
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.service-card {
		background: #fff;
		border: 1px solid #e2e8f0;
		border-top: 3px solid #3b82f6;
		border-radius: 0.9rem;
		padding: 1rem;
		transition:
			transform 220ms ease,
			box-shadow 220ms ease,
			border-color 220ms ease;
	}

	.service-card.featured {
		box-shadow: 0 16px 30px -24px rgba(15, 23, 42, 0.5);
	}

	.card-image {
		margin-bottom: 0.9rem;
	}

	.card-image img {
		display: block;
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		border-radius: 0.62rem;
	}

	.card-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.2rem;
		height: 2.2rem;
		border-radius: 0.62rem;
		background: linear-gradient(135deg, #0f4ac4, #0e3a98);
		color: #fff;
		font-size: 1rem;
		margin-bottom: 0.8rem;
	}

	.service-card h3 {
		margin: 0;
		font-size: 1.48rem;
		line-height: 1.2;
		color: #0f172a;
	}

	.service-card ul {
		margin: 0.9rem 0 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 0.42rem;
	}

	.service-card li {
		position: relative;
		padding-left: 0.95rem;
		font-size: 0.93rem;
		color: #334155;
	}

	.service-card li::before {
		content: '•';
		position: absolute;
		left: 0;
		color: #d39b24;
		font-weight: 700;
	}

	.service-tags {
		margin-top: 1.4rem;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.55rem;
	}

	.service-tags span {
		display: inline-flex;
		align-items: center;
		padding: 0.5rem 0.85rem;
		border-radius: 999px;
		font-size: 0.86rem;
		font-weight: 600;
		border: 1px solid #dbe1eb;
		background: #fff;
		color: #334155;
	}

	@media (hover: hover) {
		.service-card:hover {
			transform: translateY(-8px);
			border-color: #c2cfdf;
			box-shadow: 0 25px 42px -28px rgba(15, 23, 42, 0.6);
		}
	}

	@media (max-width: 1000px) {
		.services-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 680px) {
		.core-services {
			padding: 4.2rem var(--site-content-padding);
		}
	}
</style>
