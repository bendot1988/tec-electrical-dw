---
/** Placeholder routes until dedicated service pages exist */
const links = [
	{ label: 'Solar', href: '/solar' },
	{ label: 'EV', href: '/ev-charging' },
	{ label: 'Domestic Electrical', href: '/domestic-electrical' },
	{ label: 'Commercial Electrical', href: '/commercial-electrical' },
] as const;
---

<section class="service-quick-nav" aria-label="Service shortcuts">
	<div class="service-quick-nav-shine" aria-hidden="true"></div>
	<div class="service-quick-nav-inner">
		<nav aria-label="Popular services">
			<ul>
				{
					links.map((item) => (
						<li>
							<a href={item.href}>{item.label}</a>
						</li>
					))
				}
			</ul>
		</nav>
	</div>
</section>

<style>
	.service-quick-nav {
		position: relative;
		background: linear-gradient(180deg, #f8fafc 0%, #eef2f7 55%, #f1f5f9 100%);
		border-bottom: 1px solid rgba(148, 163, 184, 0.35);
		box-shadow: 0 8px 24px -18px rgba(15, 23, 42, 0.12);
	}

	.service-quick-nav-shine {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 3px;
		background: linear-gradient(
			90deg,
			#0f4ac4 0%,
			#3b82f6 25%,
			#38bdf8 50%,
			#3b82f6 75%,
			#0f4ac4 100%
		);
		background-size: 200% 100%;
		animation: serviceQuickNavShine 10s linear infinite;
		opacity: 0.92;
	}

	@keyframes serviceQuickNavShine {
		0% {
			background-position: 0% 50%;
		}
		100% {
			background-position: 200% 50%;
		}
	}

	.service-quick-nav-inner {
		width: 100%;
		margin: 0 auto;
		padding: 0.72rem var(--site-content-padding);
	}

	.service-quick-nav ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.55rem;
		align-items: stretch;
	}

	.service-quick-nav li {
		position: relative;
		min-width: 0;
		display: flex;
	}

	.service-quick-nav a {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		padding: 0.55rem 0.65rem;
		border-radius: var(--radius-button);
		text-align: center;
		line-height: 1.25;
		font-size: 0.88rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		color: #fff;
		background: linear-gradient(145deg, #0f4ac4 0%, #2563eb 100%);
		border: 1px solid #1e40af;
		box-shadow: 0 8px 18px -14px rgba(15, 74, 196, 0.45);
		transition:
			color 200ms cubic-bezier(0.22, 1, 0.36, 1),
			background 200ms cubic-bezier(0.22, 1, 0.36, 1),
			border-color 200ms ease,
			box-shadow 200ms ease,
			transform 200ms cubic-bezier(0.22, 1, 0.36, 1),
			filter 200ms ease;
	}

	@media (hover: hover) {
		.service-quick-nav a:hover {
			filter: brightness(1.07);
			border-color: #1d4ed8;
			box-shadow: 0 10px 24px -12px rgba(15, 74, 196, 0.5);
			transform: translateY(-2px);
		}
	}

	.service-quick-nav a:focus-visible {
		outline: 2px solid #93c5fd;
		outline-offset: 3px;
	}

	@media (prefers-reduced-motion: reduce) {
		.service-quick-nav-shine {
			animation: none;
			background: linear-gradient(90deg, #0f4ac4, #3b82f6);
			background-size: 100% 100%;
		}

		.service-quick-nav a {
			transition: color 160ms ease, background 160ms ease, border-color 160ms ease;
		}

		.service-quick-nav a:hover {
			transform: none;
		}
	}

	@media (max-width: 720px) {
		.service-quick-nav ul {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 380px) {
		.service-quick-nav ul {
			grid-template-columns: 1fr;
		}
	}
</style>
