---
const navigation = [
	{ label: 'Home', href: '/' },
	{ label: 'Services', href: '/services' },
	{ label: 'Solar', href: '/solar' },
	{ label: 'Projects', href: '/projects' },
	{ label: 'Contact', href: '/contact' },
];
---

<header class="site-header">
	<div class="container">
		<a class="brand" href="/" aria-label="Tech Electrical home">
			<img class="brand-logo" src="/tech-electrical-logo.png" alt="Tech Electrical Services Ltd" />
		</a>

		<nav class="nav" aria-label="Primary">
			<ul>
				{
					navigation.map((item) => (
						<li>
							<a href={item.href}>{item.label}</a>
						</li>
					))
				}
			</ul>
		</nav>

		<div class="actions">
			<a class="call-link" href="tel:+441160000000">Call Now</a>
			<a class="quote-link" href="#quote">Get Quote</a>
		</div>

		<button
			class="mobile-toggle"
			type="button"
			aria-label="Open menu"
			aria-expanded="false"
			aria-controls="mobile-menu"
			data-menu-toggle
		>
			<span></span>
			<span></span>
			<span></span>
		</button>
	</div>

	<div class="mobile-menu" id="mobile-menu" hidden data-menu-panel>
		<nav aria-label="Mobile primary">
			<ul>
				{
					navigation.map((item) => (
						<li>
							<a href={item.href}>{item.label}</a>
						</li>
					))
				}
			</ul>
		</nav>

		<div class="mobile-cta">
			<a class="quote-link" href="#quote">Get My Free Quote</a>
			<a class="services-link" href="/services">See All Services</a>
		</div>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: rgba(255, 255, 255, 0.96);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid rgba(15, 23, 42, 0.08);
	}

	.container {
		width: 100%;
		padding: 0.8rem var(--site-content-padding);
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1rem;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		white-space: nowrap;
	}

	.brand-logo {
		display: block;
		width: clamp(150px, 20vw, 255px);
		height: auto;
	}

	.nav ul {
		margin: 0;
		padding: 0;
		list-style: none;
		display: flex;
		justify-content: center;
		gap: 1.5rem;
		font-size: 0.94rem;
	}

	.nav a {
		color: #334155;
		font-weight: 500;
	}

	.nav a:hover {
		color: #0f4ac4;
	}

	.actions {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
	}

	.call-link,
	.quote-link {
		border-radius: 0.6rem;
		padding: 0.62rem 1rem;
		font-size: 0.88rem;
		font-weight: 600;
	}

	.call-link {
		border: 1px solid #dbe1eb;
		background: #fff;
		color: #1f2937;
	}

	.quote-link {
		background: linear-gradient(120deg, #f59e0b, #f97316);
		color: #fff;
	}

	.mobile-toggle {
		display: none;
		border: 1px solid #dbe1eb;
		background: #fff;
		width: 2.8rem;
		height: 2.8rem;
		border-radius: 0.72rem;
		padding: 0.45rem;
		align-items: center;
		justify-content: center;
		gap: 0.26rem;
		cursor: pointer;
	}

	.mobile-toggle span {
		display: block;
		width: 1.25rem;
		height: 0.12rem;
		background: #1f2937;
		border-radius: 99px;
		transition: transform 200ms ease, opacity 200ms ease;
		transform-origin: center;
	}

	.mobile-toggle[aria-expanded='true'] span:nth-child(1) {
		transform: translateY(0.38rem) rotate(45deg);
	}

	.mobile-toggle[aria-expanded='true'] span:nth-child(2) {
		opacity: 0;
	}

	.mobile-toggle[aria-expanded='true'] span:nth-child(3) {
		transform: translateY(-0.38rem) rotate(-45deg);
	}

	.mobile-menu {
		display: none;
		border-top: 1px solid #e2e8f0;
		background: #fff;
		padding: 0.3rem var(--site-content-padding) 1.15rem;
	}

	.mobile-menu nav ul {
		margin: 0;
		padding: 0.25rem 0 0.85rem;
		list-style: none;
	}

	.mobile-menu nav li + li {
		border-top: 1px solid #f1f5f9;
	}

	.mobile-menu nav a {
		display: block;
		padding: 0.86rem 0;
		font-size: 0.99rem;
		font-weight: 600;
		color: #334155;
	}

	.mobile-cta {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.6rem;
		padding-top: 0.35rem;
	}

	.mobile-cta a {
		display: inline-flex;
		justify-content: center;
		align-items: center;
		border-radius: 0.6rem;
		padding: 0.72rem 1rem;
		font-size: 0.9rem;
		font-weight: 700;
	}

	.services-link {
		border: 1px solid #dbe1eb;
		background: #fff;
		color: #1f2937;
	}

	@media (max-width: 900px) {
		.container {
			grid-template-columns: 1fr auto;
		}

		.nav,
		.actions {
			display: none;
		}

		.mobile-toggle {
			display: inline-flex;
			flex-direction: column;
		}

		.mobile-menu[data-open='true'] {
			display: block;
			animation: menuSlideDown 220ms ease;
		}

		.brand-logo {
			width: clamp(135px, 38vw, 205px);
		}
	}

	@media (min-width: 901px) {
		.mobile-menu {
			display: none !important;
		}
	}

	@keyframes menuSlideDown {
		from {
			opacity: 0;
			transform: translateY(-8px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>

<script>
	const toggleButton = document.querySelector('[data-menu-toggle]') as HTMLButtonElement | null;
	const menuPanel = document.querySelector('[data-menu-panel]') as HTMLElement | null;
	const mobileLinks = document.querySelectorAll('[data-menu-panel] a');

	if (toggleButton && menuPanel) {
		const closeMenu = () => {
			toggleButton.setAttribute('aria-expanded', 'false');
			toggleButton.setAttribute('aria-label', 'Open menu');
			menuPanel.hidden = true;
			menuPanel.dataset.open = 'false';
		};

		const openMenu = () => {
			toggleButton.setAttribute('aria-expanded', 'true');
			toggleButton.setAttribute('aria-label', 'Close menu');
			menuPanel.hidden = false;
			menuPanel.dataset.open = 'true';
		};

		toggleButton.addEventListener('click', () => {
			const isOpen = toggleButton.getAttribute('aria-expanded') === 'true';
			if (isOpen) {
				closeMenu();
				return;
			}
			openMenu();
		});

		mobileLinks.forEach((link) => {
			link.addEventListener('click', closeMenu);
		});

		window.addEventListener('resize', () => {
			if (window.innerWidth > 900) {
				closeMenu();
			}
		});
	}
</script>
