---
import { siteContact } from '../data/siteContact';

const faqs = [
	{
		question: 'Are you qualified and insured?',
		answer:
			"Yes — we're NICEIC EIC Approved, RECC and SafeContractor accredited, and fully insured for domestic and commercial work.",
	},
	{
		question: 'Do you offer emergency callouts?',
		answer:
			'Yes — we provide emergency electrical callouts where possible, with rapid fault-finding and safe temporary or permanent fixes depending on the issue.',
	},
	{
		question: 'What guarantees do I get?',
		answer:
			'All work is certified and backed by manufacturer warranties plus our own workmanship guarantee. Solar installations include IWA deposit & guarantee protection.',
	},
	{
		question: 'Do you provide certificates for electrical work?',
		answer:
			'Absolutely — every job is certified to current regulations. EIC, EICR, MEIWC and Building Regulations compliance certificates are issued as appropriate.',
	},
	{
		question: 'How does your solar installation process work?',
		answer:
			'Free consultation -> bespoke quotation -> professional install -> full handover and ongoing optimisation. Maintenance packages available.',
	},
	{
		question: 'Can you help with landlord electrical requirements?',
		answer:
			'Yes — landlord EICRs, PAT testing, fire alarm and emergency lighting testing all in one visit.',
		openByDefault: true,
	},
];
---

<section class="faq-section" aria-labelledby="faq-heading">
	<div class="faq-wrap">
		<header class="faq-head" data-reveal="fade-up">
			<p>FAQ</p>
			<h2 id="faq-heading">Frequently Asked Questions</h2>
		</header>

		<div class="faq-list">
			{
				faqs.map((item, index) => {
					const fades = ['fade-up', 'fade-down'];
					return (
					<details
						open={item.openByDefault}
						data-reveal={fades[index % 2]}
						style={`--reveal-delay: ${90 + index * 70}ms;`}
					>
						<summary>{item.question}</summary>
						<p>{item.answer}</p>
					</details>
					);
				})
			}
		</div>

		<div class="faq-contact" data-reveal="fade-up" style="--reveal-delay: 120ms;">
			<div class="faq-contact-inner">
				<h3>Still have a question?</h3>
				<p>Get in touch — we&apos;ll point you in the right direction or book a call at a time that suits you.</p>
				<ul class="faq-contact-list">
					<li>
						<span class="label">Tel</span>
						<a href={siteContact.telHref}>{siteContact.telDisplay}</a>
					</li>
					<li>
						<span class="label">Mobile</span>
						<a href={siteContact.mobileHref}>{siteContact.mobileDisplay}</a>
					</li>
					<li>
						<span class="label">Email</span>
						<a href={`mailto:${siteContact.email}`}>{siteContact.email}</a>
					</li>
				</ul>
				<div class="faq-contact-cta">
					<a class="btn-primary" href="#quote">Get a free quote</a>
					<a class="btn-outline" href={`mailto:${siteContact.email}`}>Contact us</a>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.faq-section {
		background: #f8fafc;
		padding: 5rem var(--site-content-padding) 5.8rem;
		--faq-brand: #0f4ac4;
		--faq-brand-deep: #0c3d9e;
	}

	.faq-wrap {
		max-width: 1200px;
		margin: 0 auto;
	}

	.faq-head {
		text-align: center;
		max-width: 760px;
		margin: 0 auto 1.8rem;
	}

	.faq-head p {
		margin: 0;
		font-size: 0.78rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--faq-brand);
	}

	.faq-head h2 {
		margin: 0.52rem 0 0;
		font-size: clamp(2rem, 3vw, 3rem);
		line-height: 1.1;
		color: #0f172a;
	}

	.faq-list {
		display: grid;
		gap: 0.7rem;
	}

	.faq-list details {
		border: 1px solid rgba(255, 255, 255, 0.22);
		border-radius: 0.88rem;
		background: linear-gradient(145deg, var(--faq-brand) 0%, var(--faq-brand-deep) 100%);
		padding: 0;
		overflow: hidden;
		box-shadow: 0 10px 30px -18px rgba(15, 74, 196, 0.55);
	}

	.faq-list summary {
		list-style: none;
		cursor: pointer;
		padding: 1.1rem 1.2rem;
		font-size: 1.05rem;
		font-weight: 700;
		color: #ffffff;
		position: relative;
	}

	.faq-list summary::-webkit-details-marker {
		display: none;
	}

	.faq-list summary::after {
		content: '⌄';
		position: absolute;
		right: 1.2rem;
		top: 50%;
		transform: translateY(-50%);
		font-size: 1rem;
		color: rgba(255, 255, 255, 0.92);
		transition: transform 180ms ease;
	}

	.faq-list details[open] summary::after {
		transform: translateY(-50%) rotate(180deg);
	}

	.faq-list summary:hover {
		background: rgba(255, 255, 255, 0.08);
	}

	.faq-list details p {
		margin: 0;
		padding: 0 1.2rem 1.15rem;
		color: rgba(241, 245, 249, 0.92);
		font-size: 0.98rem;
		line-height: 1.55;
		border-top: 1px solid rgba(255, 255, 255, 0.14);
		padding-top: 0.85rem;
	}

	.faq-contact {
		margin-top: 2.5rem;
	}

	.faq-contact-inner {
		max-width: 640px;
		margin: 0 auto;
		text-align: center;
		padding: 2rem 1.5rem;
		background: #ffffff;
		border: 1px solid #e2e8f0;
		border-radius: 0.9rem;
		box-shadow: 0 14px 36px -28px rgba(15, 23, 42, 0.2);
	}

	.faq-contact-inner h3 {
		margin: 0;
		font-size: clamp(1.35rem, 2.2vw, 1.65rem);
		color: #0f172a;
	}

	.faq-contact-inner > p {
		margin: 0.55rem 0 1.2rem;
		color: #64748b;
		font-size: 1rem;
		line-height: 1.55;
	}

	.faq-contact-list {
		list-style: none;
		margin: 0 0 1.25rem;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 1rem 1.75rem;
	}

	.faq-contact-list li {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.2rem;
	}

	.faq-contact-list .label {
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--faq-brand);
	}

	.faq-contact-list a {
		font-size: 1.05rem;
		font-weight: 600;
		color: #0f172a;
	}

	.faq-contact-list a:hover {
		color: var(--faq-brand);
	}

	.faq-contact-cta {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.65rem;
	}

	.btn-primary {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.78rem 1.25rem;
		border-radius: 0.55rem;
		font-weight: 700;
		font-size: 0.92rem;
		background: linear-gradient(120deg, #f59e0b, #f97316);
		color: #fff;
	}

	.btn-primary:hover {
		filter: brightness(1.05);
	}

	.btn-outline {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.76rem 1.2rem;
		border-radius: 0.55rem;
		font-weight: 700;
		font-size: 0.92rem;
		border: 1px solid #dbe1eb;
		color: #1f2937;
		background: #fff;
	}

	.btn-outline:hover {
		border-color: var(--faq-brand);
		color: var(--faq-brand);
	}

	@media (max-width: 680px) {
		.faq-section {
			padding: 4.2rem var(--site-content-padding);
		}

		.faq-list summary {
			font-size: 1rem;
			padding-right: 2.6rem;
		}
	}
</style>
