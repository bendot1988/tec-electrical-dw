---
import InnerPageHero from './InnerPageHero.astro';
import { siteContact } from '../data/siteContact';

interface BreadcrumbItem {
	label: string;
	href?: string;
}

interface BenefitItem {
	title: string;
	description: string;
}

interface AudienceClientBadge {
	logo: string;
	alt?: string;
}

interface AudienceGalleryImage {
	src: string;
	alt?: string;
}

interface AudienceItem {
	title: string;
	description: string;
	image?: string;
	imageAlt?: string;
	/** Crossfading slides; advances every `galleryIntervalMs` (default 2000). */
	imageGallery?: AudienceGalleryImage[];
	galleryIntervalMs?: number;
	clientBadge?: AudienceClientBadge;
}

interface FaqItem {
	question: string;
	answer: string;
}

interface PartnerLogo {
	name: string;
	logo: string;
	logoAlt?: string;
}

/** Full-width sections (own H2) with image, copy, and benefit bullets — used e.g. for Testing Services. */
interface ServiceModule {
	slug: string;
	title: string;
	image: string;
	imageAlt: string;
	body: string[];
	benefits: string[];
}

interface SidebarFormField {
	name: string;
	label: string;
	type: 'text' | 'email' | 'tel' | 'textarea' | 'select';
	placeholder?: string;
	required?: boolean;
	options?: string[];
}

interface SidebarFormConfig {
	title: string;
	intro?: string;
	submitLabel?: string;
	consentLabel?: string;
	fields: SidebarFormField[];
}

interface OverviewGalleryImage {
	src: string;
	alt: string;
}

interface OverviewGallery {
	heading?: string;
	intro?: string;
	images: OverviewGalleryImage[];
}

interface Props {
	eyebrow?: string;
	title: string;
	description: string;
	breadcrumbs: BreadcrumbItem[];
	backgroundImage?: string;
	heroImage: string;
	heroImageAlt: string;
	featuredImage: string;
	featuredImageAlt: string;
	featuredCaption?: string;
	serviceHeading?: string;
	serviceBody: string[];
	keyPoints?: string[];
	tokenPartnerLogos?: PartnerLogo[];
	includedItems?: string[];
	benefits?: BenefitItem[];
	audienceHeading?: string;
	audienceItems?: AudienceItem[];
	/** When set, each item renders as an H2 block with image + description + bullets; generic Benefits / Who sections are omitted. */
	serviceModules?: ServiceModule[];
	/** Optional sidebar form shown in place of the featured image. Visual-only by default. */
	sidebarForm?: SidebarFormConfig;
	/** Optional image grid in the overview left column (below key points) to balance a tall sidebar. */
	overviewGallery?: OverviewGallery;
	faqs: FaqItem[];
}

const {
	eyebrow = 'Service',
	title,
	description,
	breadcrumbs,
	backgroundImage,
	heroImage,
	heroImageAlt,
	featuredImage,
	featuredImageAlt,
	featuredCaption,
	serviceHeading = 'The service',
	serviceBody,
	keyPoints = [],
	tokenPartnerLogos = [],
	includedItems = [],
	benefits = [],
	audienceHeading = "Who's it for?",
	audienceItems = [],
	serviceModules = [],
	sidebarForm,
	overviewGallery,
	faqs,
} = Astro.props;

	const overviewGalleryImages = overviewGallery?.images ?? [];
	const hasOverviewGallery = overviewGalleryImages.length > 0;

	const hasServiceModules = serviceModules.length > 0;
---

<main class="service-detail-page">
	<InnerPageHero
		eyebrow={eyebrow}
		title={title}
		description={description}
		backgroundImage={backgroundImage}
		featuredImage={heroImage}
		featuredAlt={heroImageAlt}
		breadcrumbs={breadcrumbs}
	/>

	<section class="service-overview" aria-labelledby="service-overview-heading">
		<div class="service-wrap">
			<div class="service-overview-layout">
				<div class="service-copy" data-reveal="fade-left">
					<h2 id="service-overview-heading">{serviceHeading}</h2>
					{serviceBody.map((paragraph) => <p>{paragraph}</p>)}
					{
						keyPoints.length > 0 && (
							<ul class="service-key-points" aria-label="Key points" data-reveal-stagger="90">
								{keyPoints.map((point) => <li data-reveal="zoom">{point}</li>)}
							</ul>
						)
					}
					{
						hasOverviewGallery && (
							<div
								class="service-overview-gallery"
								aria-label={overviewGallery?.heading ?? 'Project photography'}
								data-reveal="fade-up"
							>
								{(overviewGallery?.heading || overviewGallery?.intro) && (
									<div class="service-overview-gallery-head">
										{overviewGallery?.heading && <h3 class="service-overview-gallery-title">{overviewGallery.heading}</h3>}
										{overviewGallery?.intro && <p class="service-overview-gallery-intro">{overviewGallery.intro}</p>}
									</div>
								)}
								<ul class="service-overview-gallery-grid" data-reveal-stagger="80">
									{
										overviewGalleryImages.map((img) => (
											<li class="service-overview-gallery-item">
												<button
													type="button"
													class="service-overview-gallery-trigger"
													data-overview-gallery-src={img.src}
													data-overview-gallery-alt={img.alt}
													aria-haspopup="dialog"
													aria-controls="service-overview-gallery-dialog"
													aria-label={`View larger photo: ${img.alt}`}
												>
													<img src={img.src} alt="" loading="lazy" decoding="async" width="640" height="480" />
												</button>
											</li>
										))
									}
								</ul>
								<dialog id="service-overview-gallery-dialog" class="overview-gallery-dialog" aria-modal="true">
									<div class="overview-gallery-dialog-panel">
										<button type="button" class="overview-gallery-dialog-close" aria-label="Close">
											<span aria-hidden="true">×</span>
										</button>
										<img class="overview-gallery-dialog-img" src="" alt="" />
									</div>
								</dialog>
							</div>
						)
					}
					{
						tokenPartnerLogos.length > 0 && (
							<div class="service-token-logos" aria-label="Featured partner brands" data-reveal="fade-up">
								<ul class:list={['service-token-logos-list', tokenPartnerLogos.length === 1 && 'is-single']}>
									{tokenPartnerLogos.map((brand) => (
										<li class="service-token-logos-item">
											<img
												src={brand.logo}
												alt={brand.logoAlt ?? `${brand.name} logo`}
												loading="lazy"
												decoding="async"
												width="132"
												height="64"
											/>
										</li>
									))}
								</ul>
							</div>
						)
					}
				</div>
				<aside class:list={['service-sidebar', sidebarForm && 'has-form']} data-reveal="fade-right" style="--reveal-delay: 110ms;">
					{
						sidebarForm ? (
							<form class="service-sidebar-form" data-reveal="zoom" style="--reveal-delay: 130ms;">
								<div class="service-sidebar-form-head">
									<p class="service-sidebar-form-eyebrow">Quick Enquiry</p>
									<h3>{sidebarForm.title}</h3>
									{sidebarForm.intro && <p>{sidebarForm.intro}</p>}
								</div>
								<div class="service-sidebar-fields">
									{
										sidebarForm.fields.map((field) => (
											<label>
												<span>{field.label}</span>
												{field.type === 'textarea' ? (
													<textarea
														name={field.name}
														placeholder={field.placeholder}
														rows={4}
														required={field.required ?? false}
													></textarea>
												) : field.type === 'select' ? (
													<select name={field.name} required={field.required ?? false}>
														<option value="">Select...</option>
														{(field.options ?? []).map((opt) => (
															<option value={opt}>{opt}</option>
														))}
													</select>
												) : (
													<input
														type={field.type}
														name={field.name}
														placeholder={field.placeholder}
														required={field.required ?? false}
													/>
												)}
											</label>
										))
									}
								</div>
								<label class="service-sidebar-consent">
									<input type="checkbox" required />
									<span
										>{sidebarForm.consentLabel ??
											'I confirm I agree to the Terms & Conditions and understand how my data will be processed in line with GDPR.'}</span
									>
								</label>
								<button type="submit">{sidebarForm.submitLabel ?? 'Send enquiry'}</button>
							</form>
						) : (
							<figure class="service-sidebar-image" data-reveal="zoom" style="--reveal-delay: 130ms;">
								<img src={featuredImage} alt={featuredImageAlt} loading="eager" decoding="async" />
								{featuredCaption && <figcaption>{featuredCaption}</figcaption>}
							</figure>
						)
					}

					{includedItems.length > 0 && (
						<div class="service-included" data-reveal="fade-up" style="--reveal-delay: 180ms;">
							<h3>What&apos;s included</h3>
							<ul>
								{includedItems.map((item) => <li>{item}</li>)}
							</ul>
						</div>
					)}
				</aside>
			</div>
		</div>
	</section>

	{
		hasServiceModules && (
			<section class="service-modules" aria-label="Service categories">
				<div class="service-wrap service-modules-wrap" data-reveal-stagger="100">
					{
						serviceModules.map((mod, index) => (
							<article
								class:list={['service-module', index % 2 === 1 && 'service-module--reverse']}
								id={mod.slug}
								data-reveal="fade-up"
							>
								<h2 class="service-module-title">{mod.title}</h2>
								<div class="service-module-grid">
									<figure class="service-module-figure">
										<img src={mod.image} alt={mod.imageAlt} loading="lazy" decoding="async" />
									</figure>
									<div class="service-module-body">
										{mod.body.map((paragraph) => <p>{paragraph}</p>)}
										{mod.benefits.length > 0 && (
											<div class="service-module-benefits">
												<p class="service-module-benefits-label">Why it matters</p>
												<ul>
													{mod.benefits.map((line) => (
														<li>{line}</li>
													))}
												</ul>
											</div>
										)}
									</div>
								</div>
							</article>
						))
					}
				</div>
			</section>
		)
	}

	{
		!hasServiceModules && benefits.length > 0 && (
			<section class="service-benefits" aria-labelledby="service-benefits-heading">
				<div class="service-wrap">
					<h2 id="service-benefits-heading" data-reveal="fade-up">
						Benefits
					</h2>
					<div class="card-grid" data-reveal-stagger="100">
						{
							benefits.map((benefit, index) => (
								<article class="info-card" data-reveal={index % 2 === 0 ? 'fade-left' : 'fade-right'}>
									<h3>{benefit.title}</h3>
									<p>{benefit.description}</p>
								</article>
							))
						}
					</div>
				</div>
			</section>
		)
	}

	{
		!hasServiceModules && audienceItems.length > 0 && (
			<section class="service-audience" aria-labelledby="service-audience-heading">
				<div class="service-wrap">
					<h2 id="service-audience-heading" data-reveal="fade-up">
						{audienceHeading}
					</h2>
					<div class="card-grid audience-grid" data-reveal-stagger="110">
						{
							audienceItems.map((item, index) => (
								<article class="info-card" data-reveal={index % 2 === 0 ? 'fade-left' : 'fade-right'}>
									{(item.image || (item.imageGallery && item.imageGallery.length > 0)) && (
										<div class="info-card-image">
											<div class="info-card-image-frame">
												{
													item.imageGallery && item.imageGallery.length > 0 ? (
														<div
															class="info-card-gallery"
															data-audience-gallery
															data-interval={item.galleryIntervalMs ?? 2000}
															role="img"
															aria-label={item.imageAlt ?? item.title}
														>
															{item.imageGallery.map((slide, slideIndex) => (
																<img
																	class:list={[
																		'info-card-gallery-slide',
																		slideIndex === 0 && 'is-active',
																	]}
																	src={slide.src}
																	alt={slide.alt ?? ''}
																	loading={slideIndex === 0 ? 'eager' : 'lazy'}
																	decoding="async"
																	aria-hidden={slideIndex === 0 ? undefined : 'true'}
																/>
															))}
														</div>
													) : (
														<img
															src={item.image}
															alt={item.imageAlt ?? item.title}
															loading="lazy"
															decoding="async"
														/>
													)
												}
												{
													item.clientBadge && (
														<span class="info-card-client-badge" aria-hidden="true">
															<img
																src={item.clientBadge.logo}
																alt={item.clientBadge.alt ?? 'Client logo'}
																loading="lazy"
																decoding="async"
															/>
														</span>
													)
												}
											</div>
										</div>
									)}
									<h3>{item.title}</h3>
									<p>{item.description}</p>
								</article>
							))
						}
					</div>
				</div>
			</section>
		)
	}

	<section class="service-faq" aria-labelledby="service-faq-heading">
		<div class="service-wrap">
			<h2 id="service-faq-heading" data-reveal="fade-up">FAQs</h2>
			<div class="faq-list" data-reveal-stagger="85">
				{
					faqs.map((item, index) => (
						<details data-reveal={index % 2 === 0 ? 'fade-left' : 'fade-right'}>
							<summary>{item.question}</summary>
							<p>{item.answer}</p>
						</details>
					))
				}
			</div>
		</div>
	</section>
	<slot name="after-faq" />

	<section class="service-cta" aria-labelledby="service-cta-heading">
		<div class="service-wrap">
			<div class="service-cta-card" data-reveal="zoom">
				<h2 id="service-cta-heading">Ready to get started?</h2>
				<p>
					Talk to our team about your project and we&apos;ll help you plan the right solution for your property and
					budget.
				</p>
				<div class="service-cta-actions">
					<a href="#quote">Get a free quote</a>
					<a class="is-outline" href={siteContact.telHref}>Call {siteContact.telDisplay}</a>
				</div>
			</div>
		</div>
	</section>
</main>

<script>
	function initServiceOverviewGalleryLightbox() {
		const dialog = document.getElementById('service-overview-gallery-dialog');
		const img = dialog?.querySelector('.overview-gallery-dialog-img');
		const closeBtn = dialog?.querySelector('.overview-gallery-dialog-close');
		const panel = dialog?.querySelector('.overview-gallery-dialog-panel');
		if (!dialog || !img || !closeBtn || !panel) return;

		function openFromTrigger(btn) {
			const src = btn.getAttribute('data-overview-gallery-src');
			const alt = btn.getAttribute('data-overview-gallery-alt') ?? '';
			if (!src) return;
			img.setAttribute('src', src);
			img.setAttribute('alt', alt);
			dialog.showModal();
		}

		document.querySelectorAll('[data-overview-gallery-src]').forEach((btn) => {
			btn.addEventListener('click', () => openFromTrigger(btn));
		});

		closeBtn.addEventListener('click', () => dialog.close());

		panel.addEventListener('click', (e) => {
			if (e.target === panel) dialog.close();
		});

		dialog.addEventListener('close', () => {
			img.removeAttribute('src');
			img.setAttribute('alt', '');
		});
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initServiceOverviewGalleryLightbox, { once: true });
	} else {
		initServiceOverviewGalleryLightbox();
	}
</script>

<style>
	.service-detail-page {
		background: #f8fafc;
	}

	.service-wrap {
		max-width: 1200px;
		margin: 0 auto;
	}

	.service-overview,
	.service-modules,
	.service-benefits,
	.service-audience,
	.service-faq,
	.service-cta {
		padding: 1.2rem var(--site-content-padding) 0;
	}

	.service-overview-layout {
		display: grid;
		grid-template-columns: 1.45fr minmax(280px, 1fr);
		gap: 1.05rem;
	}

	.service-overview-layout > * {
		min-width: 0;
	}

	.service-copy {
		background: #fff;
		border: 1px solid #e2e8f0;
		border-radius: 0.95rem;
		padding: 1.25rem;
	}

	.service-copy h2 {
		margin: 0;
		font-size: clamp(1.55rem, 2.2vw, 2rem);
		color: #0f172a;
	}

	.service-copy p {
		margin: 0.72rem 0 0;
		font-size: 0.98rem;
		line-height: 1.65;
		color: #475569;
	}

	.service-key-points {
		margin: 1rem 0 0;
		padding: 0;
		list-style: none;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 0.62rem;
	}

	.service-key-points li {
		position: relative;
		padding: 0.82rem 0.85rem 0.82rem 2.35rem;
		font-size: 0.91rem;
		line-height: 1.45;
		color: #1e293b;
		font-weight: 600;
		background: linear-gradient(180deg, #f8fbff 0%, #eef5ff 100%);
		border: 1px solid #d6e4ff;
		border-radius: 0.72rem;
		box-shadow: 0 8px 18px -18px rgba(15, 23, 42, 0.35);
		transition:
			transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
			border-color 220ms cubic-bezier(0.22, 1, 0.36, 1),
			box-shadow 220ms cubic-bezier(0.22, 1, 0.36, 1),
			background 220ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	.service-key-points li::before {
		content: '';
		position: absolute;
		left: 0.82rem;
		top: 0.94rem;
		width: 1rem;
		height: 1rem;
		border-radius: 999px;
		background: #16a34a;
		box-shadow: inset 0 0 0 2px rgba(255, 255, 255, 0.92);
	}

	.service-key-points li::after {
		content: '';
		position: absolute;
		left: 1.14rem;
		top: 1.23rem;
		width: 0.31rem;
		height: 0.15rem;
		border-left: 2px solid #fff;
		border-bottom: 2px solid #fff;
		transform: rotate(-45deg);
	}

	.service-overview-gallery {
		margin-top: 1.05rem;
		padding-top: 1rem;
		border-top: 1px solid #e2e8f0;
	}

	.service-overview-gallery-head {
		margin-bottom: 0.72rem;
	}

	.service-overview-gallery-title {
		margin: 0;
		font-size: 1.02rem;
		font-weight: 700;
		color: #0f172a;
		letter-spacing: -0.02em;
	}

	.service-overview-gallery-intro {
		margin: 0.35rem 0 0;
		font-size: 0.88rem;
		line-height: 1.55;
		color: #64748b;
	}

	.service-overview-gallery-grid {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.55rem;
	}

	.service-overview-gallery-item {
		list-style: none;
		border-radius: 0.65rem;
		overflow: hidden;
		border: 1px solid #dbe1eb;
		background: #f1f5f9;
		box-shadow: 0 8px 20px -16px rgba(15, 23, 42, 0.35);
	}

	.service-overview-gallery-item::marker {
		content: '';
	}

	.service-overview-gallery-trigger {
		display: block;
		width: 100%;
		margin: 0;
		padding: 0;
		border: none;
		background: none;
		cursor: zoom-in;
		line-height: 0;
	}

	.service-overview-gallery-trigger:focus-visible {
		outline: 3px solid #3b82f6;
		outline-offset: 2px;
	}

	.service-overview-gallery-trigger img {
		display: block;
		width: 100%;
		height: clamp(120px, 22vw, 168px);
		object-fit: cover;
		transition: transform 240ms cubic-bezier(0.22, 1, 0.36, 1), filter 240ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	@media (hover: hover) {
		.service-overview-gallery-trigger:hover img {
			transform: scale(1.03);
			filter: saturate(1.05) contrast(1.02);
		}
	}

	.overview-gallery-dialog {
		margin: 0;
		max-width: none;
		max-height: none;
		width: min(100vw, 100%);
		height: min(100vh, 100%);
		padding: 0;
		border: none;
		background: transparent;
	}

	.overview-gallery-dialog::backdrop {
		background: rgba(248, 250, 252, 0.94);
		backdrop-filter: blur(2px);
	}

	.overview-gallery-dialog-panel {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 100dvh;
		padding: 3.25rem 1rem 1.5rem;
		box-sizing: border-box;
	}

	.overview-gallery-dialog-close {
		position: fixed;
		top: 1rem;
		right: 1rem;
		z-index: 2;
		display: grid;
		place-items: center;
		width: 2.75rem;
		height: 2.75rem;
		margin: 0;
		padding: 0;
		border: 1px solid #cbd5e1;
		border-radius: 999px;
		background: #fff;
		color: #0f172a;
		font-size: 1.65rem;
		line-height: 1;
		font-weight: 400;
		cursor: pointer;
		box-shadow: 0 8px 24px -12px rgba(15, 23, 42, 0.35);
		transition:
			background 180ms ease,
			border-color 180ms ease,
			transform 180ms ease;
	}

	.overview-gallery-dialog-close:hover {
		background: #f8fafc;
		border-color: #94a3b8;
	}

	.overview-gallery-dialog-close:focus-visible {
		outline: 3px solid #3b82f6;
		outline-offset: 2px;
	}

	.overview-gallery-dialog-img {
		display: block;
		max-width: min(92vw, 1200px);
		max-height: min(82vh, 900px);
		width: auto;
		height: auto;
		object-fit: contain;
		border-radius: 0.5rem;
		border: 1px solid #e2e8f0;
		box-shadow: 0 24px 48px -28px rgba(15, 23, 42, 0.35);
		background: #fff;
	}

	.service-token-logos {
		margin-top: 0.95rem;
		padding-top: 0.8rem;
		border-top: 1px solid #e2e8f0;
	}

	.service-token-logos-list {
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.65rem;
