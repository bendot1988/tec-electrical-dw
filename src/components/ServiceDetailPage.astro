<script>
	const initAudienceGalleries = () => {
		const galleries = document.querySelectorAll('[data-audience-gallery]:not([data-gallery-ready])');
		const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		galleries.forEach((gallery) => {
			gallery.setAttribute('data-gallery-ready', 'true');
			const slides = Array.from(gallery.querySelectorAll('.info-card-gallery-slide'));
			if (slides.length < 2 || prefersReducedMotion) return;

			const intervalMs = Number(gallery.getAttribute('data-interval')) || 2000;
			let activeIndex = slides.findIndex((slide) => slide.classList.contains('is-active'));
			if (activeIndex < 0) activeIndex = 0;

			const showSlide = (index) => {
				slides.forEach((slide, slideIndex) => {
					const isActive = slideIndex === index;
					slide.classList.toggle('is-active', isActive);
					slide.setAttribute('aria-hidden', isActive ? 'false' : 'true');
				});
			};

			window.setInterval(() => {
				activeIndex = (activeIndex + 1) % slides.length;
				showSlide(activeIndex);
			}, intervalMs);
		});
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initAudienceGalleries, { once: true });
	} else {
		initAudienceGalleries();
	}

	document.addEventListener('astro:page-load', initAudienceGalleries);
</script>
