---
import CookieBanner from '../components/CookieBanner.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import QuoteDrawer from '../components/QuoteDrawer.astro';
import SiteFooter from '../components/SiteFooter.astro';
import {
	absoluteUrl,
	defaultOgImage,
	defaultOgImageHeight,
	defaultOgImageWidth,
	getCanonicalUrl,
	siteName,
} from '../data/siteSeo';

interface Props {
	title?: string;
	description?: string;
	canonical?: string;
	ogImage?: string;
	ogImageAlt?: string;
	noindex?: boolean;
}

const {
	title = 'Tec Electrical | Electricians Leicestershire',
	description = 'NICEIC-approved electricians for installs, testing, solar, battery storage and EV charging across Leicestershire.',
	ogImage = defaultOgImage,
	ogImageAlt = 'Tec Electrical electrical and solar installation services',
	noindex = false,
} = Astro.props;

const canonical = getCanonicalUrl(Astro.url.pathname);
const ogImageUrl = absoluteUrl(ogImage);
---

<!doctype html>
<html lang="en-GB">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="google-site-verification" content="2V0xNAu90UHKcTJvIVYrbrOmW6dS5J4tjHrE4NV0sVM" />
		<GoogleAnalytics />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Sora:wght@500;600;700;800&display=swap"
			rel="stylesheet"
		/>
		<link rel="icon" href="/favicon.ico" sizes="32x32" />
		<link rel="icon" type="image/png" href="/favicon-32.png" sizes="32x32" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />
		<meta property="og:site_name" content={siteName} />
		<meta property="og:locale" content="en_GB" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:width" content={String(defaultOgImageWidth)} />
		<meta property="og:image:height" content={String(defaultOgImageHeight)} />
		<meta property="og:image:alt" content={ogImageAlt} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<meta name="twitter:image:alt" content={ogImageAlt} />
		{noindex ? (
			<meta name="robots" content="noindex, nofollow" />
		) : (
			<meta name="robots" content="index, follow, max-image-preview:large" />
		)}
		<slot name="head" />
	</head>
	<body>
		<slot />
		<QuoteDrawer />
		<SiteFooter />
		<CookieBanner />
		<script>
			import '../scripts/enquiryForms';
		</script>
	</body>
</html>

<style>
	:global(:root) {
		--site-content-padding: 5%;
		--font-body: 'Inter', 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
		--font-heading: 'Sora', 'Inter', 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
		/* Primary CTA: amber 500 → deeper amber only (readable white label; avoids pale yellow) */
		--cta-main-gradient: linear-gradient(
			92deg,
			#f59e0b 0%,
			#d97706 100%
		);
		--cta-main-border: 1px solid rgba(217, 119, 6, 0.55);
		--cta-main-shadow:
			0 10px 28px -14px rgba(180, 83, 9, 0.38),
			0 4px 14px -8px rgba(245, 158, 11, 0.28);
		/* All buttons & pill CTAs, one radius rule site-wide */
		--radius-button: 999px;
	}

	:global(*) {
		box-sizing: border-box;
	}

	:global(html),
	:global(body) {
		margin: 0;
		padding: 0;
		font-family: var(--font-body);
		color: #111827;
		background: #f8fafc;
	}

	:global(h1),
	:global(h2),
	:global(h3),
	:global(h4),
	:global(h5),
	:global(h6) {
		font-family: var(--font-heading);
		letter-spacing: -0.015em;
	}

	:global(a) {
		color: inherit;
		text-decoration: none;
	}

	/* Default + fade-up: enter from below */
	:global([data-reveal]),
	:global([data-reveal='fade-up']) {
		opacity: 0;
		transform: translate3d(0, 22px, 0);
		transition:
			opacity 560ms cubic-bezier(0.22, 1, 0.36, 1),
			transform 560ms cubic-bezier(0.22, 1, 0.36, 1),
			filter 560ms cubic-bezier(0.22, 1, 0.36, 1);
		transition-delay: var(--reveal-delay, 0ms);
		will-change: opacity, transform;
	}

	:global([data-reveal='fade-down']) {
		opacity: 0;
		transform: translate3d(0, -22px, 0);
		transition:
			opacity 560ms cubic-bezier(0.22, 1, 0.36, 1),
			transform 560ms cubic-bezier(0.22, 1, 0.36, 1),
			filter 560ms cubic-bezier(0.22, 1, 0.36, 1);
		transition-delay: var(--reveal-delay, 0ms);
		will-change: opacity, transform;
	}

	:global([data-reveal='fade-left']),
	:global([data-reveal='left']) {
		opacity: 0;
		transform: translate3d(-26px, 0, 0);
		transition:
			opacity 560ms cubic-bezier(0.22, 1, 0.36, 1),
			transform 560ms cubic-bezier(0.22, 1, 0.36, 1),
			filter 560ms cubic-bezier(0.22, 1, 0.36, 1);
		transition-delay: var(--reveal-delay, 0ms);
		will-change: opacity, transform;
	}

	:global([data-reveal='fade-right']),
	:global([data-reveal='right']) {
		opacity: 0;
		transform: translate3d(26px, 0, 0);
		transition:
			opacity 560ms cubic-bezier(0.22, 1, 0.36, 1),
			transform 560ms cubic-bezier(0.22, 1, 0.36, 1),
			filter 560ms cubic-bezier(0.22, 1, 0.36, 1);
		transition-delay: var(--reveal-delay, 0ms);
		will-change: opacity, transform;
	}

	:global([data-reveal='zoom']) {
		opacity: 0;
		transform: scale(0.96);
		transition:
			opacity 560ms cubic-bezier(0.22, 1, 0.36, 1),
			transform 560ms cubic-bezier(0.22, 1, 0.36, 1),
			filter 560ms cubic-bezier(0.22, 1, 0.36, 1);
		transition-delay: var(--reveal-delay, 0ms);
		will-change: opacity, transform;
	}

	:global([data-reveal='blur']) {
		opacity: 0;
		transform: translate3d(0, 12px, 0);
		filter: blur(6px);
		transition:
			opacity 560ms cubic-bezier(0.22, 1, 0.36, 1),
			transform 560ms cubic-bezier(0.22, 1, 0.36, 1),
			filter 560ms cubic-bezier(0.22, 1, 0.36, 1);
		transition-delay: var(--reveal-delay, 0ms);
		will-change: opacity, transform, filter;
	}

	:global([data-reveal].is-revealed),
	:global([data-reveal='fade-up'].is-revealed),
	:global([data-reveal='fade-down'].is-revealed),
	:global([data-reveal='fade-left'].is-revealed),
	:global([data-reveal='fade-right'].is-revealed),
	:global([data-reveal='left'].is-revealed),
	:global([data-reveal='right'].is-revealed),
	:global([data-reveal='zoom'].is-revealed),
	:global([data-reveal='blur'].is-revealed) {
		opacity: 1;
		transform: translate3d(0, 0, 0) scale(1);
		filter: blur(0);
	}

	:global(.enquiry-form-shell) {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	:global(.enquiry-honeypot) {
		position: absolute;
		left: -9999px;
		width: 1px;
		height: 1px;
		overflow: hidden;
		opacity: 0;
		pointer-events: none;
	}

	:global(.enquiry-form-success) {
		padding: 1.35rem 1.1rem;
		border-radius: 0.85rem;
		background: linear-gradient(180deg, #ecfdf5 0%, #d1fae5 100%);
		border: 1px solid #6ee7b7;
		text-align: center;
		color: #065f46;
		box-shadow: 0 12px 28px -20px rgba(5, 150, 105, 0.45);
	}

	:global(.enquiry-form-success-title) {
		margin: 0;
		font-family: var(--font-heading);
		font-size: 1.2rem;
		font-weight: 700;
		line-height: 1.35;
		color: #047857;
	}

	:global(.enquiry-form-success-text) {
		margin: 0.45rem 0 0;
		font-size: 0.92rem;
		line-height: 1.5;
		color: #065f46;
	}

	:global(.enquiry-form-error) {
		margin: 0;
		padding: 0.75rem 0.9rem;
		border-radius: 0.65rem;
		background: #fef2f2;
		border: 1px solid #fecaca;
		color: #b91c1c;
		font-size: 0.9rem;
		line-height: 1.45;
	}

	@media (prefers-reduced-motion: reduce) {
		:global([data-reveal]),
		:global([data-reveal='fade-up']),
		:global([data-reveal='fade-down']),
		:global([data-reveal='fade-left']),
		:global([data-reveal='fade-right']),
		:global([data-reveal='left']),
		:global([data-reveal='right']),
		:global([data-reveal='zoom']),
		:global([data-reveal='blur']) {
			opacity: 1;
			transform: none;
			filter: none;
			transition: none;
		}
	}
</style>

<script>
	const revealItems = Array.from(document.querySelectorAll('[data-reveal]'));

	const staggerGroups = Array.from(document.querySelectorAll('[data-reveal-stagger]'));
	staggerGroups.forEach((group) => {
		const staggerStep = Number(group.getAttribute('data-reveal-stagger')) || 80;
		const children = Array.from(group.querySelectorAll<HTMLElement>('[data-reveal]'));
		children.forEach((child, index) => {
			if (!child.style.getPropertyValue('--reveal-delay')) {
				child.style.setProperty('--reveal-delay', `${index * staggerStep}ms`);
			}
		});
	});

	if (revealItems.length > 0) {
		if ('IntersectionObserver' in window) {
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add('is-revealed');
							observer.unobserve(entry.target);
						}
					});
				},
				{ threshold: 0.15, rootMargin: '0px 0px -8% 0px' },
			);

			revealItems.forEach((item) => observer.observe(item));
		} else {
			revealItems.forEach((item) => item.classList.add('is-revealed'));
		}
	}
</script>
