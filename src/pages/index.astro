---
import CoverageSection from '../components/CoverageSection.astro';
import CoreServicesSection from '../components/CoreServicesSection.astro';
import FaqSection from '../components/FaqSection.astro';
import HeroSection from '../components/HeroSection.astro';
import RecentWorkSection from '../components/RecentWorkSection.astro';
import RenewableEnergySection from '../components/RenewableEnergySection.astro';
import ServiceQuickNav from '../components/ServiceQuickNav.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SolarPackagesSection from '../components/SolarPackagesSection.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Tec Electrical | Electricians Leicestershire"
	description="NICEIC-approved electricians in Leicestershire for installs, testing, fault finding, emergencies, solar, battery storage and EV charging. Get a free quote."
>
	<link slot="head" rel="preload" as="image" href="/hero-solar-roof.png" fetchpriority="high" />
	<LocalBusinessSchema slot="head" />
	<SiteHeader />
	<main>
		<HeroSection />
		<ServiceQuickNav />
		<RenewableEnergySection />
		<SolarPackagesSection />
		<CoreServicesSection />
		<RecentWorkSection />
		<TestimonialsSection />
		<CoverageSection />
		<FaqSection />
	</main>
</Layout>
